// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id              String   @id @default(cuid())
  title           String
  abstract        String?  @db.Text
  introduction    String?  @db.Text
  materialsMethods String? @db.Text
  results         String?  @db.Text
  discussion      String?  @db.Text
  conclusion      String?  @db.Text
  references      String?  @db.Text
  
  status          String   @default("DRAFT") // DRAFT, SUBMITTED, IN_REVIEW, ACCEPTED, REJECTED, PUBLISHED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  authors         AuthorMapping[]
  media           Media[]
}

model AuthorMapping {
  id              String   @id @default(cuid())
  articleId       String
  name            String
  address         String?
  sequence        Int      @default(0) // To order authors 1 to 8

  article         Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model Media {
  id              String   @id @default(cuid())
  articleId       String
  publicId        String   // Cloudinary public_id
  secureUrl       String   @db.Text
  resourceType    String   @default("image") // image, raw (for pdf/docs)
  section         String?  // The section of the article this media belongs to if applicable
  createdAt       DateTime @default(now())

  article         Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  @@index([articleId])
}

// Admin Users are primarily managed via Environment Variables for this phase 
// but we include a User model in case we need database-level editors/reviewers later.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // hashed
  name      String?
  role      String   @default("AUTHOR") // ADMIN, EDITOR, REVIEWER, AUTHOR
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
